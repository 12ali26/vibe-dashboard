DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=3000
HOST_WORKSPACES_DIR=/home/ubuntu/projects
WORKSPACES_DIR=/home/ubuntu/projects

# Existing code-server mode. Use this when code-server already runs on the host.
CODE_SERVER_PORT=8080
CODE_SERVER_URL=

# Bundled code-server mode. Used only with: docker compose --profile bundled-ide up -d
BUNDLED_CODE_SERVER_HOST=0.0.0.0
BUNDLED_CODE_SERVER_PORT=8080
CODE_SERVER_PASSWORD=change-me

# Local non-Docker development only
PORT=3000
SERVER_IP=
